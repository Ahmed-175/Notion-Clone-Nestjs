# ==============================================================================
# Notion Clone Monorepo Environment Configuration
# Copy this file to apps/backend/.env or run `npm run setup` to do it automatically.
# ==============================================================================

# MongoDB Connection URL
MONGO_URL=mongodb://localhost:27017/notion-clone

# JWT Signing Secret
JWT_SECRET=your-jwt-secret-bla-bla-bla

# Google OAuth Credentials
# You can obtain these from the Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend Server Port (Defaults to 8000 if not specified)
PORT=8000
